{
  "schema_version": "1.0.0",
  "config_name": "cz_debt_counseling_ai_source_policy",
  "jurisdiction": "CZ",
  "domain": "dluhove_poradenstvi",
  "language": "cs",
  "as_of_date": "2026-04-03",
  "timezone": "Europe/Prague",
  "description": "Komplexní konfigurační JSON pro whitelist zdrojů, aktivaci právních větví, pravidla jistoty závěru, časovou validaci a denylist pro AI asistenta v oblasti dluhového poradenství v ČR.",
  "design_principles": {
    "primary_law_first": true,
    "effective_text_required": true,
    "always_on_core": true,
    "conditional_branches": true,
    "advisory_sources_cannot_override_law": true,
    "deny_unofficial_summaries_as_primary_support": true,
    "confidence_controlled_by_source_strength": true,
    "temporal_validation_required_for_sensitive_domains": true
  },
  "certainty_model": {
    "levels": [
      {
        "id": "certain",
        "rank": 3,
        "description": "Lze použít pouze při přímé opoře v primárním závazném předpisu, správném účinném znění a dostatečném skutkovém stavu.",
        "allowed_phrases": [
          "podle účinné právní úpravy platí",
          "právní závěr je",
          "v tomto režimu se použije"
        ],
        "forbidden_if_not_met": [
          "jednoznačně platí",
          "je jisté, že",
          "musí to být takto"
        ]
      },
      {
        "id": "supported_but_conditional",
        "rank": 2,
        "description": "Právní opora existuje, ale výsledek závisí na konkrétním skutkovém detailu, datu nebo doplňujícím režimu.",
        "required_disclaimer": "Závěr závisí na konkrétních okolnostech a může se změnit podle data, typu dluhu nebo procesního stavu."
      },
      {
        "id": "informational_only",
        "rank": 1,
        "description": "Zdroj je informativní, metodický nebo procesní. Nesmí sám vytvořit závazný právní závěr.",
        "required_disclaimer": "Jde o orientační nebo metodickou informaci, nikoli samostatnou závaznou právní oporu."
      }
    ],
    "promotion_rules": [
      {
        "id": "promote_to_certain",
        "requires_all": [
          "primary_support_present",
          "effective_text_verified",
          "no_source_conflict_unresolved",
          "material_facts_sufficient"
        ]
      },
      {
        "id": "cap_to_supported_if_missing_fact",
        "if_any": [
          "missing_key_date",
          "missing_debtor_status",
          "missing_public_vs_private_debt_classification",
          "missing_procedural_stage"
        ],
        "cap": "supported_but_conditional"
      },
      {
        "id": "cap_to_informational_if_only_advisory",
        "if_all": [
          "only_advisory_sources_present"
        ],
        "cap": "informational_only"
      }
    ]
  },
  "global_gates": {
    "primary_support_gate": {
      "enabled": true,
      "rule": "Bez opory v T1 nebo relevantní kombinaci T1+T2/T3 nesmí být finální závěr označen jako certain."
    },
    "temporal_gate": {
      "enabled": true,
      "rule": "U časově citlivých oblastí musí být ověřeno účinné znění ke dni skutkového děje nebo ke dni relevantního podání."
    },
    "advisory_gate": {
      "enabled": true,
      "rule": "Metodiky, portály a kalkulátory lze použít jen podpůrně a nesmí samy vytvořit jistý právní závěr."
    },
    "fact_sufficiency_gate": {
      "enabled": true,
      "rule": "Pokud chybí rozhodující skutkové informace, jistota odpovědi se snižuje."
    }
  },
  "source_conflict_resolution": {
    "precedence_order": [
      "zakon",
      "narizeni_vlady",
      "vyhlaska",
      "oficialni_metodika",
      "portal_info",
      "kalkulator",
      "secondary_summary",
      "unofficial_source"
    ],
    "rules": [
      {
        "id": "law_over_methodology",
        "rule": "Při konfliktu mezi zákonem a metodikou vždy vítězí zákon."
      },
      {
        "id": "effective_text_over_old_summary",
        "rule": "Při konfliktu mezi účinným zněním a starším shrnutím vždy vítězí účinné znění."
      },
      {
        "id": "primary_over_secondary",
        "rule": "Pokud je dostupný primární zdroj, nesmí být sekundární shrnutí hlavní oporou."
      },
      {
        "id": "official_over_unofficial",
        "rule": "Neoficiální zdroj nesmí přebít oficiální zdroj."
      }
    ]
  },
  "temporal_rules": {
    "sensitive_domains": [
      "insolvence",
      "oddluzeni",
      "nezabavitelne_castky",
      "davky",
      "socialni_pomoc",
      "verejnopravni_vymahani"
    ],
    "milestones": [
      {
        "id": "insolvency_reform_2024",
        "effective_from": "2024-10-01",
        "label": "Nový režim oddlužení a navazující formulářová úprava",
        "required_for_domains": [
          "insolvence",
          "oddluzeni",
          "formular_oddluzeni"
        ]
      },
      {
        "id": "social_reform_2025",
        "effective_from": "2025-10-01",
        "label": "Nový dávkový režim sociální pomoci",
        "required_for_domains": [
          "davky",
          "socialni_pomoc",
          "bydleni",
          "rozpoctovy_dopad"
        ]
      },
      {
        "id": "social_transition_2025_2026",
        "effective_from": "2025-10-01",
        "effective_to": "2026-04-30",
        "label": "Přechodné období starého a nového dávkového režimu",
        "required_for_domains": [
          "davky",
          "socialni_pomoc"
        ]
      }
    ]
  },
  "tiers": [
    {
      "id": "T1",
      "name": "zavazne_jadro",
      "mode": "always_on",
      "purpose": "Základní právní rámec pro exekuce, výkon rozhodnutí, srážky a oddlužení.",
      "allowed_for_final_conclusion": true,
      "can_support_certain": true
    },
    {
      "id": "T2",
      "name": "hmotnepravni_vetve",
      "mode": "conditional",
      "purpose": "Vznik dluhu, platnost závazku, spotřebitel, smlouvy, SJM, ručení a soukromoprávní dopady.",
      "allowed_for_final_conclusion": true,
      "can_support_certain": true
    },
    {
      "id": "T3",
      "name": "procesni_a_verejnopravni_vetve",
      "mode": "conditional",
      "purpose": "Veřejnoprávní dluhy, daňové vymáhání, zvláštní soudní řízení a rodinné procesní přesahy.",
      "allowed_for_final_conclusion": true,
      "can_support_certain": true
    },
    {
      "id": "T4",
      "name": "prijmy_davky_rozpoctovy_kontext",
      "mode": "conditional",
      "purpose": "Životní minimum, dávky, bydlení, udržitelnost domácnosti a praktický dopad dluhů.",
      "allowed_for_final_conclusion": false,
      "can_support_certain": false
    },
    {
      "id": "T5",
      "name": "metodiky_formulare_portaly_tarify",
      "mode": "conditional",
      "purpose": "Formuláře, workflow, oficiální portály, metodiky a podpůrné výpočty.",
      "allowed_for_final_conclusion": false,
      "can_support_certain": false
    }
  ],
